# =============================================================================
# Ong Gestor Pro - Git Ignore
# =============================================================================

# =============================================================================
# Environment Files
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# Node.js / Dependencies
# =============================================================================
node_modules/
dist/
build/
.pnpm-store/
*.log

# =============================================================================
# Database
# =============================================================================
*.sqlite
*.db
mysql_data/

# =============================================================================
# IDE and Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# =============================================================================
# Test Coverage
# =============================================================================
coverage/
.nyc_output/

# =============================================================================
# Build Artifacts
# =============================================================================
*.exe
*.dll
*.so
*.dylib
main

# =============================================================================
# Development Files
# =============================================================================
.ong-logs/
*.local

# =============================================================================
# Backend
# =============================================================================
ong-management-backend/*.env

# =============================================================================
# Frontend
# =============================================================================
Ong-managment-front/dist/
Ong-managment-front/.ong-logs/