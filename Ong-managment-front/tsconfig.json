{
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "server/**/*",
    "drizzle.config.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],

    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,
    "isolatedModules": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "allowJs": true,
    "forceConsistentCasingInFileNames": true,

    "types": [
      "node"
    ],

    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"],
      "@drizzle/*": ["./drizzle/*"]
    }
  }
}